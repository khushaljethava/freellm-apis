---
import Base from '../layouts/Base.astro';
import posts from '../../../data/blog.json';
import FilterBar from '../components/FilterBar.astro';
import AdSlot from '../components/AdSlot.astro';
import providers from '../../../data/providers.json';
import models from '../../../data/models.json';

const modelCount = (id) => models.filter(m => m.provider_id === id && !m.deprecated).length;
const maxContext = (id) => {
  const ctxs = models.filter(m => m.provider_id === id && !m.deprecated).map(m => m.context_window);
  if (!ctxs.length) return '—';
  const c = Math.max(...ctxs);
  return c >= 1_000_000 ? `${Math.round(c/1_000_000)}M` : `${Math.round(c/1_000)}K`;
};
const cardLabel = { no: 'No card', registration: 'Email signup', phone: 'Phone verify', yes: 'Card required' };
const cardBadge = { no: 'badge-green', registration: 'badge-blue', phone: 'badge-orange', yes: 'badge-red' };

const permanent = providers.filter(p => p.free_type === 'permanent').sort((a,b) => modelCount(b.id) - modelCount(a.id));
const credits = providers.filter(p => p.free_type === 'credits').sort((a,b) => (b.credit_amount_usd||0) - (a.credit_amount_usd||0));
const totalModels = models.filter(m => !m.deprecated).length;
const lastVerified = providers[0]?.last_verified ?? '';

const quickPick = permanent.find(p => p.credit_card_required === 'no');
const quickPickCtx = quickPick ? maxContext(quickPick.id) : null;
const quickPickModels = quickPick ? modelCount(quickPick.id) : 0;

const faqs = [
  {
    q: "What is the best free LLM API?",
    a: `The best free LLM API depends on your use case. Groq is the fastest, Google Gemini has the largest free context window, and GitHub Models needs no separate signup. All ${providers.length} providers listed here offer a free LLM API with no upfront cost.`,
  },
  {
    q: "How do I get a free LLM API key?",
    a: "Pick a provider from the tables above, click Get key, and sign up on their console. Most issue a free LLM API key instantly with just an email — no credit card. Then set it as your API key and start making requests.",
  },
  {
    q: "Are there free LLM APIs with no credit card?",
    a: `Yes. Many providers here offer a free LLM API with no credit card required — the "No card" badge marks them. Groq, Google Gemini, GitHub Models, and Mistral all give free API keys without any payment details.`,
  },
  {
    q: "What is the cheapest LLM API?",
    a: "The cheapest LLM API is a free one. Every provider on this page has a free tier or free credits, so you pay nothing to start. For high volume, compare paid pricing per provider once your free LLM API calls run out.",
  },
  {
    q: "Are there open source LLM APIs?",
    a: "Yes. Providers like Groq, Together AI, and DeepInfra serve open source LLM models such as Llama and Mistral through a free LLM API. You get the best open source LLM models via a hosted, OpenAI-compatible endpoint without running your own hardware.",
  },
  {
    q: "Are there open source LLM API keys available for free?",
    a: "Yes. You can get a free API key from any provider on this page and call open source LLM models through it. That gives you open source LLM API keys without a credit card — Groq, Together AI, and DeepInfra all serve open-weight models this way.",
  },
  {
    q: "What is the cheapest LLM API provider?",
    a: "For free usage, any provider here is the cheapest LLM API — you pay nothing to start. When you need paid scale, run an LLM API pricing comparison across providers, since per-token rates for a cheap LLM API vary widely by model and region.",
  },
  {
    q: "Can I make free LLM API calls without limits?",
    a: "Free LLM API calls come with per-minute and per-day rate limits, not unlimited use. The limits are generous enough for prototyping and light production. When you outgrow a free tier, switch providers or upgrade to a paid plan.",
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: 'freellm.site',
      url: 'https://www.freellm.site/',
      description: `Directory of ${providers.length} free LLM API providers and ${totalModels} models.`,
    },
    {
      '@type': 'Organization',
      name: 'freellm.site',
      url: 'https://www.freellm.site/',
      logo: 'https://www.freellm.site/og-default.png',
      sameAs: ['https://github.com/khushaljethava/freellm-apis'],
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(f => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---
<Base
  title="Free LLM API — Free LLM API Keys from 30+ Providers | freellm.site"
  description={`Find a free LLM API with no credit card. ${providers.length} providers, ${totalModels} models — Groq, Gemini, Mistral, GitHub Models. Get your free LLM API key in seconds.`}
  schema={schema}
>
  <div class="hero">
    <div class="hero-eyebrow">Free &amp; verified · Updated {lastVerified}</div>
    <h1>Every free LLM API.<br/><em>One place.</em></h1>
    <p>Permanent free tiers and free-credit plans from {providers.length} providers — no hunting, no paywalls. Find your key in seconds.</p>
    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-number">{providers.length}</span>
        <span class="stat-label">Providers</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">{totalModels}</span>
        <span class="stat-label">Models</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">{permanent.length}</span>
        <span class="stat-label">Always free</span>
      </div>
    </div>
  </div>

  {quickPick && (
    <div class="quick-pick">
      <span class="quick-pick-label">Quick pick</span>
      <div class="quick-pick-sep"></div>
      <div class="quick-pick-content">
        <span class="quick-pick-name">{quickPick.name}</span>
        <span class="quick-pick-meta">— {quickPickModels} models · {quickPickCtx} context · no card required · free forever</span>
      </div>
      <a href={quickPick.signup_url} target="_blank" rel="noopener" class="quick-pick-cta">Get free key →</a>
    </div>
  )}

  <AdSlot variant="top" />

  <FilterBar />

  <h2 class="section-title">Permanent free tiers</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Provider</th>
          <th>Models</th>
          <th>Card?</th>
          <th>Max context</th>
          <th>Last verified</th>
          <th>Get key</th>
        </tr>
      </thead>
      <tbody>
        {permanent.map(p => (
          <tr data-free-type="permanent" data-card-required={p.credit_card_required}>
            <td><a href={`/providers/${p.id}/`}>{p.name}</a></td>
            <td>{modelCount(p.id)}</td>
            <td><span class={`badge ${cardBadge[p.credit_card_required]}`}>{cardLabel[p.credit_card_required]}</span></td>
            <td>{maxContext(p.id)}</td>
            <td>{p.last_verified}</td>
            <td><a href={p.signup_url} target="_blank" rel="noopener">Get key →</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2 class="section-title">Free credits on signup</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Provider</th>
          <th>Credits</th>
          <th>Expiry</th>
          <th>Card?</th>
          <th>Models</th>
          <th>Last verified</th>
          <th>Get key</th>
        </tr>
      </thead>
      <tbody>
        {credits.map(p => (
          <tr data-free-type="credits" data-card-required={p.credit_card_required}>
            <td><a href={`/providers/${p.id}/`}>{p.name}</a></td>
            <td>{p.credit_amount_usd ? `$${p.credit_amount_usd}` : 'Free tier'}</td>
            <td>{p.credit_expiry ?? '—'}</td>
            <td><span class={`badge ${cardBadge[p.credit_card_required]}`}>{cardLabel[p.credit_card_required]}</span></td>
            <td>{modelCount(p.id)}</td>
            <td>{p.last_verified}</td>
            <td><a href={p.signup_url} target="_blank" rel="noopener">Get key →</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <AdSlot variant="bottom" />

  <section class="seo-content">
    <h2>Every free LLM API in one directory</h2>
    <p>
      Finding a free LLM API that works — without a credit card — shouldn't take an afternoon of
      tab-hopping. This directory tracks {providers.length} providers and {totalModels} models, from
      always-free tiers to free-credit plans, so you can grab a free LLM API key and start building in
      minutes. Every LLM API here exposes an
      <a href="/blog/openai-compatible-api-guide/">OpenAI-compatible endpoint</a>, so switching
      providers is a one-line change.
    </p>
    <p>
      Whether you need the cheapest LLM API for a side project, the best open source LLM models like
      Llama and Mistral, or a fast free LLM API for coding, the tables above compare them on models,
      context window, and whether a card is required. Need paid scale later? Start free, then run an
      LLM API pricing comparison across providers. For hands-on guides, see our
      <a href="/blog/best-free-llm-apis-2026/">roundup of the best free LLM APIs</a>,
      <a href="/blog/best-open-source-llm-apis/">best open source LLM APIs</a>, and
      <a href="/blog/best-free-llm-apis-for-coding/">best free LLM APIs for coding</a>.
    </p>

    <h2>Guides</h2>
    <ul class="guide-list">
      {posts.map(p => (
        <li><a href={`/blog/${p.slug}/`}>{p.title}</a></li>
      ))}
    </ul>

    <h2>Free LLM API FAQ</h2>
    <div class="faq-list">
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  .seo-content {
    max-width: 760px;
    margin: 3rem auto 0;
    padding: 0 1rem 2rem;
  }
  .seo-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
  }
  .seo-content > p {
    line-height: 1.7;
    color: var(--text-muted, #6b7280);
    margin: 0 0 1rem;
  }
  .seo-content a { color: var(--accent, #6366f1); }
  .faq-list { margin-top: 0.5rem; }
  .faq-item { margin-bottom: 1.25rem; }
  .faq-item h3 { font-size: 1.05rem; font-weight: 600; margin: 0 0 0.35rem; }
  .faq-item p { margin: 0; line-height: 1.7; color: var(--text-muted, #6b7280); }
</style>
