---
import Base from '../../layouts/Base.astro';
import providers from '../../../../data/providers.json';
import AdSlot from '../../components/AdSlot.astro';
import models from '../../../../data/models.json';

export function getStaticPaths() {
  return providers.map(p => ({ params: { slug: p.id }, props: { provider: p } }));
}

const { provider } = Astro.props;
const providerModels = models.filter(m => m.provider_id === provider.id && !m.deprecated);
const firstModel = providerModels[0];

// --- Data-driven unique overview (raises per-page content uniqueness) ---
const regionLabel = {
  global: 'globally available', china: 'China-based', europe: 'Europe-based',
  india: 'India-based', japan: 'Japan-based', korea: 'Korea-based',
  middle_east: 'Middle East-based', sea: 'Southeast Asia-based',
};
const maxCtx = providerModels.length ? Math.max(...providerModels.map(m => m.context_window)) : 0;
const maxRpm = providerModels.map(m => m.rpm).filter(Boolean);
const modalities = [...new Set(providerModels.flatMap(m => m.modalities))];
const fmtCtxOverview = (c) => c >= 1_000_000 ? `${Math.round(c/1_000_000)}M` : `${Math.round(c/1_000)}K`;

const freeClause = provider.free_type === 'credits' && provider.credit_amount_usd != null
  ? `$${provider.credit_amount_usd} in free credits${provider.credit_expiry ? ` (${provider.credit_expiry})` : ''}`
  : 'a permanent free tier';
const cardClause = {
  no: 'No credit card is required to start',
  registration: 'Signup needs only an email — no credit card',
  phone: 'Signup requires phone verification but no credit card',
  yes: 'A credit card is required to activate the free tier',
}[provider.credit_card_required];

const overview = [
  `${provider.name} is a ${regionLabel[provider.region] ?? 'available'} LLM API provider offering ${freeClause}.`,
  providerModels.length
    ? `You get ${providerModels.length} free model${providerModels.length !== 1 ? 's' : ''}${maxCtx ? ` with up to a ${fmtCtxOverview(maxCtx)}-token context window` : ''}${modalities.length ? `, supporting ${modalities.join(', ')}` : ''}.`
    : `Model availability is listed below.`,
  maxRpm.length ? `Free requests are rate-limited to around ${Math.max(...maxRpm)} per minute.` : '',
  `${cardClause}, and the endpoint at ${provider.base_url} is OpenAI-compatible, so you can point existing OpenAI SDK code at ${provider.name} by changing only the base URL and API key.`,
].filter(Boolean).join(' ');

// --- Related providers (same region, else same free tier), top by model count ---
const modelCountOf = (id) => models.filter(m => m.provider_id === id && !m.deprecated).length;
const pool = providers.filter(p => p.id !== provider.id);
const sameRegion = pool.filter(p => p.region === provider.region);
const related = (sameRegion.length >= 3 ? sameRegion : pool.filter(p => p.free_type === provider.free_type))
  .sort((a, b) => modelCountOf(b.id) - modelCountOf(a.id))
  .slice(0, 4);

const guides = [
  { slug: 'best-free-llm-apis-2026', title: 'Best Free LLM APIs in 2026' },
  { slug: 'openai-compatible-api-guide', title: 'What Is an OpenAI-Compatible API' },
  { slug: 'best-free-llm-apis-for-coding', title: 'Best Free LLM APIs for Coding' },
];

const cardLabel = { no: '✅ No', registration: '📧 Email', phone: '📱 Phone', yes: '💳 Yes' };

const fmtCtx = (c) => c >= 1_000_000 ? `${Math.round(c/1_000_000)}M` : `${Math.round(c/1_000)}K`;

const pythonSnippet = `from openai import OpenAI

client = OpenAI(
    base_url="${provider.base_url}",
    api_key="YOUR_API_KEY",  # get at ${provider.signup_url}
)
response = client.chat.completions.create(
    model="${firstModel?.model_id ?? 'MODEL_ID'}",
    messages=[{"role": "user", "content": "Hello!"}],
)
print(response.choices[0].message.content)`;

const curlSnippet = `curl ${provider.base_url}/chat/completions \\
  -H "Authorization: Bearer YOUR_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "${firstModel?.model_id ?? 'MODEL_ID'}",
    "messages": [{"role": "user", "content": "Hello!"}]
  }'`;

const pageUrl = `https://www.freellm.site/providers/${provider.id}/`;
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.freellm.site/' },
        { '@type': 'ListItem', position: 2, name: `${provider.name} Free LLM API`, item: pageUrl },
      ],
    },
    {
      '@type': 'SoftwareApplication',
      name: `${provider.name} Free LLM API`,
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Any',
      url: pageUrl,
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
        description: provider.credit_card_required === 'no'
          ? 'Free tier, no credit card required'
          : 'Free tier available',
      },
    },
  ],
};
---
<Base
  title={`${provider.name} Free LLM API — Rate Limits, Models & Setup | freellm.site`}
  description={`${provider.notes}. Base URL: ${provider.base_url}. ${providerModels.length} free model${providerModels.length !== 1 ? 's' : ''} available.`}
  schema={schema}
>
  <div class="breadcrumb">
    <a href="/">Home</a><span>›</span><span>{provider.name}</span>
  </div>

  <h1 style="font-size:1.8rem;font-weight:800;margin-bottom:1rem">{provider.name} Free LLM API</h1>

  <p class="provider-overview" style="color:#374151;line-height:1.6;margin-bottom:1.25rem">{overview}</p>

  <div class="provider-meta">
    <div class="row">
      <span class="label">Base URL</span>
      <button class="copy-url" id="copy-btn">{provider.base_url}</button>
    </div>
    <div class="row"><span class="label">Card required</span><span>{cardLabel[provider.credit_card_required]}</span></div>
    {provider.free_type === 'credits' && provider.credit_amount_usd != null && (
      <div class="row"><span class="label">Free credits</span><span>${provider.credit_amount_usd} USD ({provider.credit_expiry})</span></div>
    )}
    <div class="row"><span class="label">Notes</span><span>{provider.notes}</span></div>
    <div class="row"><span class="label">Last verified</span><span>{provider.last_verified}</span></div>
    <div class="row">
      <a href={provider.signup_url} target="_blank" rel="noopener"
         style="background:#0066cc;color:#fff;padding:0.5rem 1.25rem;border-radius:6px;font-weight:600;font-size:0.9rem;display:inline-block">
        Get Free API Key →
      </a>
    </div>
  </div>

  <AdSlot variant="top" />

  {providerModels.length > 0 && (
    <>
      <h2 class="section-title">Free Models</h2>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Model ID</th><th>Context</th><th>Modalities</th><th>RPM</th><th>RPD</th></tr></thead>
          <tbody>
            {providerModels.map(m => (
              <tr>
                <td><code>{m.model_id}</code></td>
                <td>{fmtCtx(m.context_window)}</td>
                <td>{m.modalities.join(', ')}</td>
                <td>{m.rpm ?? '—'}</td>
                <td>{m.rpd ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </>
  )}

  <h2 class="section-title">Quick Start</h2>
  <div class="snippets">
    <div class="snippet-block">
      <div class="snippet-label">Python (OpenAI SDK)</div>
      <pre>{pythonSnippet}</pre>
    </div>
    <div class="snippet-block">
      <div class="snippet-label">curl</div>
      <pre>{curlSnippet}</pre>
    </div>
  </div>

  {related.length > 0 && (
    <>
      <h2 class="section-title">Related Free LLM API Providers</h2>
      <ul class="related-links">
        {related.map(p => (
          <li><a href={`/providers/${p.id}/`}>{p.name} free LLM API</a> — {modelCountOf(p.id)} free model{modelCountOf(p.id) !== 1 ? 's' : ''}</li>
        ))}
      </ul>
    </>
  )}

  <h2 class="section-title">Guides</h2>
  <ul class="related-links">
    {guides.map(g => (
      <li><a href={`/blog/${g.slug}/`}>{g.title}</a></li>
    ))}
  </ul>

  <AdSlot variant="bottom" />
</Base>

<script define:vars={{ baseUrl: provider.base_url }}>
  const btn = document.getElementById('copy-btn');
  if (btn) {
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText(baseUrl);
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = orig, 1500);
    });
  }
</script>
