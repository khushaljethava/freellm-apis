---
import Base from '../../layouts/Base.astro';
import posts from '../../../../data/blog.json';

const sorted = [...posts].sort((a, b) => b.date.localeCompare(a.date));
---
<Base
  title="Blog — Free LLM API Guides & Tutorials | freellm.site"
  description="Guides, tutorials, and comparisons for free LLM APIs. Learn how to use Groq, Gemini, GitHub Models and 90+ free AI providers."
>
  <div class="blog-hero">
    <h1>Blog</h1>
    <p>Guides and tutorials for using free LLM APIs.</p>
  </div>

  <div class="blog-list">
    {sorted.map(post => (
      <a href={`/blog/${post.slug}/`} class="blog-card">
        <div class="blog-card-meta">
          <time datetime={post.date}>{post.date}</time>
          <div class="blog-tags">
            {post.tags.slice(0, 3).map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
        <h2>{post.title}</h2>
        <p>{post.description}</p>
        <span class="read-more">Read more →</span>
      </a>
    ))}
  </div>
</Base>

<style>
  .blog-hero {
    text-align: center;
    padding: 3rem 1rem 2rem;
  }
  .blog-hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .blog-hero p {
    color: var(--text-muted, #6b7280);
    font-size: 1.1rem;
  }
  .blog-list {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .blog-card {
    display: block;
    padding: 1.5rem;
    border: 1px solid var(--border, #e5e7eb);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .blog-card:hover {
    border-color: var(--accent, #6366f1);
    box-shadow: 0 2px 12px rgba(99,102,241,0.08);
  }
  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .blog-card-meta time {
    font-size: 0.8rem;
    color: var(--text-muted, #6b7280);
  }
  .blog-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .tag {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    background: var(--tag-bg, #f3f4f6);
    border-radius: 999px;
    color: var(--text-muted, #6b7280);
  }
  .blog-card h2 {
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    line-height: 1.4;
  }
  .blog-card p {
    color: var(--text-muted, #6b7280);
    font-size: 0.95rem;
    margin: 0 0 1rem;
    line-height: 1.6;
  }
  .read-more {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent, #6366f1);
  }
</style>
